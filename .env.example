NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# PostgreSQL (Railway'de DATABASE_URL otomatik set edilir)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/servis_takip

# Redis (Railway'de REDIS_URL otomatik set edilir)
REDIS_URL=redis://localhost:6379

# JWT — üretimde en az 32 karakter rastgele string kullan
JWT_ACCESS_SECRET=change_me_access_secret_minimum_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_minimum_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# CORS
CORS_ORIGIN=http://localhost:5173
